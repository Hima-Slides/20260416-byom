                \u001b[38;2;121;125;149mSummarize conversation history to reduce context window usage\u001b[39m\u001b[19;1H\u001b[2K \u001b[38;2;121;125;149m▎\u001b[39m \u001b[38;2;183;191;220m/clear\u001b[39m                    \u001b[38;2;121;125;149mAbandon this session and start fresh\u001b[39m\u001b[20;1H\u001b[2K \u001b[38;2;121;125;149m▎\u001b[39m \u001b[38;2;183;191;220m/chronicle\u001b[39m                \u001b[38;2;121;125;149mSession history tools and insights\u001b[39m\u001b[21;1H\u001b[2K \u001b[38;2;121;125;149m▎\u001b[39m \u001b[38;2;183;191;220m/changelog\u001b[39m                \u001b[38;2;121;125;149mDisplay changelog for CLI versions. Add 'summarize' to get an AI summary.\u001b[39m\u001b[22;1H\u001b[2K \u001b[38;2;121;125;149m▎\u001b[39m \u001b[38;2;183;191;220m/ask\u001b[39m                      \u001b[38;2;121;125;149mAsk a quick side question without adding to conversation history\u001b[39m\u001b[23;1H\u001b[2K \u001b[38;2;121;125;149m▎\u001b[39m \u001b[38;2;183;191;220m/allow-all\u001b[39m                \u001b[38;2;121;125;149mEnable all permissions (tools, paths, and URLs)\u001b[39m\u001b[24;1H\u001b[2K \u001b[38;2;148;226;213m▎\u001b[39m \u001b[38;2;183;191;220m/agent\u001b[39m                    \u001b[38;2;121;125;149mBrowse and select from available agents (if any)\u001b[39m\u001b[25;1H\u001b[2K \u001b[38;2;148;226;213m▎\u001b[39m \u001b[38;2;148;226;213m/add-dir\u001b[39m                  \u001b[38;2;148;226;213mAdd a directory to the allowed list for file access\u001b[39m\u001b[27;1H\u001b[2K\u001b[38;2;141;147;172m❯ \u001b[39m/\u001b[7ma\u001b[27m\u001b[38;2;121;125;149mdd-dir \u001b[39m\u001b[29;1H\u001b[2K \u001b[38;2;141;147;172m\u001b[1m/help\u001b[22m show help\u001b[39m ​\u001b[27;4H\u001b[?2026l"]
[102.894082, "o", "\u001b[?2026h\u001b[16;1H\u001b[2K \u001b[38;2;121;125;149m▎\u001b[39m \u001b[38;2;183;191;220m/delegate\u001b[39m                 \u001b[38;2;121;125;149mSend this session to GitHub and Copilot will create a PR\u001b[39m\u001b[18;1H\u001b[2K \u001b[38;2;121;125;149m▎\u001b[39m \u001b[38;2;183;191;220m/clear\u001b[39m                    \u001b[38;2;121;125;149mAbandon this session and start fresh\u001b[39m\u001b[19;1H\u001b[2K \u001b[38;2;121;125;149m▎\u001b[39m \u001b[38;2;183;191;220m/chronicle\u001b[39m                \u001b[38;2;121;125;149mSession history tools and insights\u001b[39m\u001b[20;1H\u001b[2K \u001b[38;2;121;125;149m▎\u001b[39m \u001b[38;2;183;191;220m/changelog\u001b[39m                \u001b[38;2;121;125;149mDisplay changelog for CLI versions. Add 'summarize' to get an AI summary.\u001b[39m\u001b[21;1H\u001b[2K \u001b[38;2;121;125;149m▎\u001b[39m \u001b[38;2;183;191;220m/agent\u001b[39m                    \u001b[38;2;121;125;149mBrowse and select from available agents (if any)\u001b[39m\u001b[22;1H\u001b[2K \u001b[38;2;121;125;149m▎\u001b[39m \u001b[38;2;183;191;220m/extensions\u001b[39m               \u001b[38;2;121;125;149mManage CLI extensions\u001b[39m\u001b[23;1H\u001b[2K \u001b[38;2;148;226;213m▎\u001b[39m \u001b[38;2;183;191;220m/experimental\u001b[39m             \u001b[38;2;121;125;149mShow available experimental features, or enable/disable experimental mode\u001b[39m\u001b[24;1H\u001b[2K \u001b[38;2;148;226;213m▎\u001b[39m \u001b[38;2;183;191;220m/exit\u001b[39m                     \u001b[38;2;121;125;149mExit the CLI\u001b[39m\u001b[25;1H\u001b[2K \u001b[38;2;148;226;213m▎\u001b[39m \u001b[38;2;148;226;213m/env\u001b[39m                      \u001b[38;2;148;226;213mShow loaded environment details (instructions, MCP servers, skills, agents, plugins, LSPs,…\u001b[39m\u001b[27;1H\u001b[2K\u001b[38;2;141;147;172m❯ \u001b[39m/e\u001b[7mn\u001b[27m\u001b[38;2;121;125;149mv\u001b[39m\u001b[27;5H\u001b[?2026l"]
