[96.816319, "o", "\u001b[?2026h\u001b[16;1H\u001b[2K \u001b[38;2;121;125;149m▎\u001b[39m \u001b[38;2;183;191;220m/delegate\u001b[39m                 \u001b[38;2;121;125;149mSend this session to GitHub and Copilot will create a PR\u001b[39m\u001b[17;1H\u001b[2K \u001b[38;2;121;125;149m▎\u001b[39m \u001b[38;2;183;191;220m/compact\u001b[39m                  \u001b[38;2;121;125;149mSummarize conversation history to reduce context window usage\u001b[39m\u001b[18;1H\u001b[2K \u001b[38;2;121;125;149m▎\u001b[39m \u001b[38;2;183;191;220m/clear\u001b[39m                    \u001b[38;2;121;125;149mAbandon this session and start fresh\u001b[39m\u001b[19;1H\u001b[2K \u001b[38;2;121;125;149m▎\u001b[39m \u001b[38;2;183;191;220m/changelog\u001b[39m                \u001b[38;2;121;125;149mDisplay changelog for CLI versions. Add 'summarize' to get an AI summary.\u001b[39m\u001b[20;1H\u001b[2K \u001b[38;2;121;125;149m▎\u001b[39m \u001b[38;2;183;191;220m/reset-allowed-tools\u001b[39m      \u001b[38;2;121;125;149mReset the list of allowed tools\u001b[39m\u001b[21;1H\u001b[2K \u001b[38;2;148;226;213m▎\u001b[39m \u001b[38;2;183;191;220m/keep-alive\u001b[39m               \u001b[38;2;121;125;149mManage keep-alive mode (prevents system sleep).\u001b[39m\u001b[22;1H\u001b[2K \u001b[38;2;148;226;213m▎\u001b[39m \u001b[38;2;183;191;220m/ask\u001b[39m                      \u001b[38;2;121;125;149mAsk a quick side question without adding to conversation history\u001b[39m\u001b[23;1H\u001b[2K \u001b[38;2;148;226;213m▎\u001b[39m \u001b[38;2;183;191;220m/allow-all\u001b[39m                \u001b[38;2;121;125;149mEnable all permissions (tools, paths, and URLs)\u001b[39m\u001b[27;1H\u001b[2K\u001b[38;2;141;147;172m❯ \u001b[39m/a\u001b[7md\u001b[27m\u001b[38;2;121;125;149md-dir \u001b[39m\u001b[27;5H\u001b[?2026l"]
