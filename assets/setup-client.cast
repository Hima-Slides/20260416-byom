[103.107295, "o", "\u001b[?2026h\u001b[1;1H\u001b[2K\u001b[2;1H\u001b[2K  \u001b[38;2;183;191;220mSome key features include:\u001b[39m\u001b[3;1H\u001b[2K\u001b[4;1H\u001b[2K  \u001b[38;2;141;147;172m - \u001b[39m\u001b[38;2;183;191;220mTerminal-native development with no context switching\u001b[39m\u001b[5;1H\u001b[2K  \u001b[38;2;141;147;172m - \u001b[39m\u001b[38;2;183;191;220mGitHub integration for repositories, issues, and pull requests\u001b[39m\u001b[6;1H\u001b[2K  \u001b[38;2;141;147;172m - \u001b[39m\u001b[38;2;183;191;220mSupport for Language Server Protocol (LSP) for enhanced code intelligence\u001b[39m\u001b[7;1H\u001b[2K  \u001b[38;2;141;147;172m - \u001b[39m\u001b[38;2;183;191;220mMCP-powered extensibility for custom capabilities\u001b[39m\u001b[8;1H\u001b[2K  \u001b[38;2;141;147;172m - \u001b[39m\u001b[38;2;183;191;220mFull control with previews before any action execution\u001b[39m\u001b[9;1H\u001b[2K  \u001b[38;2;141;147;172m - \u001b[39m\u001b[38;2;183;191;220mAccess to multiple AI models including Claude Sonnet\u001b[39m\u001b[10;1H\u001b[2K  \u001b[38;2;183;191;220m  4.5 and GPT-5\u001b[39m\u001b[11;1H\u001b[2K\u001b[12;1H\u001b[2K  \u001b[38;2;183;191;220mYou can interact with me using natural language prompts and various slash commands for specific functionalities like\u001b[39m\u001b[13;1H\u001b[2K  \u001b[38;2;183;191;220mmanaging permissions, configuring LSP servers, or viewing usage statistics.\u001b[39m\u001b[15;1H\u001b[2K  \u001b[38;2;183;191;220mWhat would you like to do with me today?\u001b[39m\u001b[16;1H\u001b[2K\u001b[17;1H\u001b[2K\u001b[38;2;243;139;168m✗\u001b[39m \u001b[1mUnknown command: /g \u001b[22m\u001b[18;1H\u001b[2K\u001b[19;1H\u001b[2K\u001b[38;2;137;180;250m●\u001b[39m \u001b[38;2;183;191;220mSelected custom agent: diagnose-sunbeam\u001b[39m\u001b[20;1H\u001b[2K\u001b[21;1H\u001b[2K \u001b[38;2;141;147;172m~/Debugging/Triaging/3d07b5f6-fa4e-40e4-8f96-c4019a33842f\u001b[39m                             \u001b[38;2;141;147;172mqwen3-coder:30b\u001b[39m \u001b[1m\u001b[38;2;148;226;213mdiagnose-sunbeam\u001b[39m\u001b[22m\u001b[22;1H\u001b[2K \u001b[38;2;148;226;213m▎\u001b[39m \u001b[38;2;183;191;220m/context\u001b[39m                  \u001b[38;2;121;125;149mShow context window token usage and visualization\u001b[39m\u001b[23;1H\u001b[2K \u001b[38;2;148;226;213m▎\u001b[39m \u001b[38;2;183;191;220m/extensions\u001b[39m               \u001b[38;2;121;125;149mManage CLI extensions\u001b[39m\u001b[24;1H\u001b[2K \u001b[38;2;148;226;213m▎\u001b[39m \u001b[38;2;183;191;220m/experimental\u001b[39m             \u001b[38;2;121;125;149mShow available experimental features, or enable/disable experimental mode\u001b[39m\u001b[25;1H\u001b[2K \u001b[38;2;148;226;213m▎\u001b[39m \u001b[38;2;148;226;213m/exit\u001b[39m                     \u001b[38;2;148;226;213mExit the CLI\u001b[39m\u001b[27;1H\u001b[2K\u001b[38;2;141;147;172m❯ \u001b[39m/ex\u001b[7mi\u001b[27m\u001b[38;2;121;125;149mt\u001b[39m\u001b[27;6H\u001b[?2026l"]
