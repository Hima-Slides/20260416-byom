[95.276222, "o", "\u001b[?2026h\u001b[1;1H\u001b[2K  \u001b[38;2;101;105;127m└ \u001b[39m\u001b[38;2;141;147;172m# GitHub Copilot CLI Documentation\u001b[39m\u001b[3;1H\u001b[2K\u001b[38;2;245;194;231m●\u001b[39m \u001b[38;2;183;191;220mI'm GitHub Copilot CLI, an AI coding assistant that brings the power of GitHub Copilot directly to your terminal. I\u001b[39m\u001b[4;1H\u001b[2K  \u001b[38;2;183;191;220mcan help you build, debug, and understand code through natural language conversations.\u001b[39m\u001b[5;1H\u001b[2K\u001b[6;1H\u001b[2K  \u001b[38;2;183;191;220mI'm equipped with agentic capabilities to plan and execute complex tasks, and I integrate seamlessly with your\u001b[39m\u001b[7;1H\u001b[2K  \u001b[38;2;183;191;220mGitHub workflow. I support multiple operating systems (Linux, macOS, Windows) and can be installed via various\u001b[39m\u001b[8;1H\u001b[2K  \u001b[38;2;183;191;220mmethods including Homebrew, npm, or a direct install script.\u001b[39m\u001b[9;1H\u001b[2K\u001b[10;1H\u001b[2K  \u001b[38;2;183;191;220mSome key features include:\u001b[39m\u001b[11;1H\u001b[2K\u001b[12;1H\u001b[2K  \u001b[38;2;141;147;172m - \u001b[39m\u001b[38;2;183;191;220mTerminal-native development with no context switching\u001b[39m\u001b[13;1H\u001b[2K  \u001b[38;2;141;147;172m - \u001b[39m\u001b[38;2;183;191;220mGitHub integration for repositories, issues, and pull requests\u001b[39m\u001b[14;1H\u001b[2K  \u001b[38;2;141;147;172m - \u001b[39m\u001b[38;2;183;191;220mSupport for Language Server Protocol (LSP) for enhanced code intelligence\u001b[39m\u001b[15;1H\u001b[2K  \u001b[38;2;141;147;172m - \u001b[39m\u001b[38;2;183;191;220mMCP-powered extensibility for custom capabilities\u001b[39m\u001b[16;1H\u001b[2K  \u001b[38;2;141;147;172m - \u001b[39m\u001b[38;2;183;191;220mFull control with previews before any action execution\u001b[39m\u001b[17;1H\u001b[2K  \u001b[38;2;141;147;172m - \u001b[39m\u001b[38;2;183;191;220mAccess to multiple AI models including Claude Sonnet\u001b[39m\u001b[18;1H\u001b[2K  \u001b[38;2;183;191;220m  4.5 and GPT-5\u001b[39m\u001b[19;1H\u001b[2K\u001b[20;1H\u001b[2K  \u001b[38;2;183;191;220mYou can interact with me using natural language prompts and various slash commands for specific functionalities like\u001b[39m\u001b[21;1H\u001b[2K  \u001b[38;2;183;191;220mmanaging permissions, configuring LSP servers, or viewing usage statistics.\u001b[39m\u001b[22;1H\u001b[2K\u001b[23;1H\u001b[2K  \u001b[38;2;183;191;220mWhat would you like to do with me today?\u001b[39m\u001b[24;1H\u001b[2K\u001b[25;1H\u001b[2K \u001b[38;2;141;147;172m~/Debugging/Triaging/3d07b5f6-fa4e-40e4-8f96-c4019a33842f\u001b[39m                                              \u001b[38;2;141;147;172mqwen3-coder:30b\u001b[39m\u001b[27;1H\u001b[2K\u001b[38;2;141;147;172m❯ \u001b[39m\u001b[7m \u001b[27m\u001b[29;1H\u001b[2K \u001b[38;2;141;147;172m\u001b[1m/\u001b[22m commands\u001b[39m \u001b[38;2;141;147;172m·\u001b[39m \u001b[38;2;141;147;172m\u001b[1m?\u001b[22m help\u001b[39m ​\u001b[27;3H\u001b[?2026l"]
[95.316175, "o", "\u001b[?2026h\u001b[1;1H\u001b[2K\u001b[38;2;245;194;231m●\u001b[39m \u001b[38;2;183;191;220mI'm GitHub Copilot CLI, an AI coding assistant that brings the power of GitHub Copilot directly to your terminal. I\u001b[39m\u001b[2;1H\u001b[2K  \u001b[38;2;183;191;220mcan help you build, debug, and understand code through natural language conversations.\u001b[39m\u001b[3;1H\u001b[2K\u001b[4;1H\u001b[2K  \u001b[38;2;183;191;220mI'm equipped with agentic capabilities to plan and execute complex tasks, and I integrate seamlessly with your\u001b[39m\u001b[5;1H\u001b[2K  \u001b[38;2;183;191;220mGitHub workflow. I support multiple operating systems (Linux, macOS, Windows) and can be installed via various\u001b[39m\u001b[6;1H\u001b[2K  \u001b[38;2;183;191;220mmethods including Homebrew, npm, or a direct install script.\u001b[39m\u001b[7;1H\u001b[2K\u001b[8;1H\u001b[2K  \u001b[38;2;183;191;220mSome key features include:\u001b[39m\u001b[10;1H\u001b[2K  \u001b[38;2;141;147;172m - \u001b[39m\u001b[38;2;183;191;220mTerminal-native development with no context switching\u001b[39m\u001b[11;1H\u001b[2K  \u001b[38;2;141;147;172m - \u001b[39m\u001b[38;2;183;191;220mGitHub integration for repositories, issues, and pull requests\u001b[39m\u001b[12;1H\u001b[2K  \u001b[38;2;141;147;172m - \u001b[39m\u001b[38;2;183;191;220mSupport for Language Server Protocol (LSP) for enhanced code intelligence\u001b[39m\u001b[13;1H\u001b[2K  \u001b[38;2;141;147;172m - \u001b[39m\u001b[38;2;183;191;220mMCP-powered extensibility for custom capabilities\u001b[39m\u001b[14;1H\u001b[2K  \u001b[38;2;141;147;172m - \u001b[39m\u001b[38;2;183;191;220mFull control with previews before any action execution\u001b[39m\u001b[15;1H\u001b[2K  \u001b[38;2;141;147;172m - \u001b[39m\u001b[38;2;183;191;220mAccess to multiple AI models including Claude Sonnet\u001b[39m\u001b[16;1H\u001b[2K  \u001b[38;2;183;191;220m  4.5 and GPT-5\u001b[39m\u001b[17;1H\u001b[2K\u001b[18;1H\u001b[2K  \u001b[38;2;183;191;220mYou can interact with me using natural language prompts and various slash commands for specific functionalities like\u001b[39m\u001b[19;1H\u001b[2K  \u001b[38;2;183;191;220mmanaging permissions, configuring LSP servers, or viewing usage statistics.\u001b[39m\u001b[20;1H\u001b[2K\u001b[21;1H\u001b[2K  \u001b[38;2;183;191;220mWhat would you like to do with me today?\u001b[39m\u001b[23;1H\u001b[2K\u001b[38;2;243;139;168m✗\u001b[39m \u001b[1mUnknown command: /g \u001b[22m\u001b[27;3H\u001b[?2026l"]
