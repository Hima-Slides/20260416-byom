[97.575321, "o", "\u001b[?2026h\u001b[1;1H\u001b[2K\u001b[2;1H\u001b[2K  \u001b[38;2;183;191;220mSome key features include:\u001b[39m\u001b[4;1H\u001b[2K  \u001b[38;2;141;147;172m - \u001b[39m\u001b[38;2;183;191;220mTerminal-native development with no context switching\u001b[39m\u001b[5;1H\u001b[2K  \u001b[38;2;141;147;172m - \u001b[39m\u001b[38;2;183;191;220mGitHub integration for repositories, issues, and pull requests\u001b[39m\u001b[6;1H\u001b[2K  \u001b[38;2;141;147;172m - \u001b[39m\u001b[38;2;183;191;220mSupport for Language Server Protocol (LSP) for enhanced code intelligence\u001b[39m\u001b[7;1H\u001b[2K  \u001b[38;2;141;147;172m - \u001b[39m\u001b[38;2;183;191;220mMCP-powered extensibility for custom capabilities\u001b[39m\u001b[8;1H\u001b[2K  \u001b[38;2;141;147;172m - \u001b[39m\u001b[38;2;183;191;220mFull control with previews before any action execution\u001b[39m\u001b[9;1H\u001b[2K  \u001b[38;2;141;147;172m - \u001b[39m\u001b[38;2;183;191;220mAccess to multiple AI models including Claude Sonnet\u001b[39m\u001b[10;1H\u001b[2K  \u001b[38;2;183;191;220m  4.5 and GPT-5\u001b[39m\u001b[11;1H\u001b[2K\u001b[12;1H\u001b[2K  \u001b[38;2;183;191;220mYou can interact with me using natural language prompts and various slash commands for specific functionalities like\u001b[39m\u001b[13;1H\u001b[2K  \u001b[38;2;183;191;220mmanaging permissions, configuring LSP servers, or viewing usage statistics.\u001b[39m\u001b[14;1H\u001b[2K\u001b[15;1H\u001b[2K  \u001b[38;2;183;191;220mWhat would you like to do with me today?\u001b[39m\u001b[16;1H\u001b[2K\u001b[17;1H\u001b[2K\u001b[38;2;243;139;168m✗\u001b[39m \u001b[1mUnknown command: /g \u001b[22m\u001b[18;1H\u001b[2K\u001b[19;1H\u001b[2K \u001b[1m\u001b[38;2;245;194;231mCustom Agents\u001b[39m\u001b[22m\u001b[21;1H\u001b[2K \u001b[38;2;141;147;172mSelect Agent:\u001b[39m\u001b[22;1H\u001b[2K \u001b[38;2;148;226;213m❯ 1. Default (current)\u001b[39m\u001b[23;1H\u001b[2K   2. diagnose-sunbeam\u001b[38;2;141;147;172m · user\u001b[39m\u001b[25;1H\u001b[2K \u001b[38;2;141;147;172mManage Agents:\u001b[39m\u001b[26;1H\u001b[2K   3. Create new agent...\u001b[27;1H\u001b[2K   4. Learn more about custom agents\u001b[28;1H\u001b[2K\u001b[29;1H\u001b[2K \u001b[1m\u001b[38;2;183;191;220m↑↓\u001b[39m\u001b[22m\u001b[38;2;141;147;172m to navigate · \u001b[39m\u001b[1m\u001b[38;2;183;191;220mEnter\u001b[39m\u001b[22m\u001b[38;2;141;147;172m to select · \u001b[39m\u001b[1m\u001b[38;2;183;191;220mEsc\u001b[39m\u001b[22m\u001b[38;2;141;147;172m to cancel\u001b[39m\u001b[?2026l"]
